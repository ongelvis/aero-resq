import cv2
import requests
import time
import numpy as np
from collections import deque
from ultralytics import YOLO

# --- CONFIGURATION ---
MODEL_PATH = 'yolov8n-pose.pt' 
BACKEND_URL = "http://localhost:8000/telemetry"
VIDEO_SOURCE = r"ai_engine\swimming_data\Active Drowning.mp4"  # Your aerial video
SEND_INTERVAL = 2 
MAX_HISTORY = 45

# NEW: Detection parameters optimized for aerial views
DETECTION_CONFIDENCE = 0.25  # Lower threshold to catch partial views
AERIAL_MODE = True  # Enable aerial-specific optimizations

# Dictionary to store keypoint history
person_history = {}

def enhance_aerial_detection(results, frame):
    """
    Post-process detection results specifically for aerial views
    where swimmers might appear as small objects
    """
    if results[0].boxes is None:
        return results
    
    # Get current detections
    boxes = results[0].boxes
    keypoints = results[0].keypoints
    
    # For aerial views, small clusters of pixels might be swimmers
    # We'll use image pyramid and sliding window for small detections
    # This is a simplified version - consider implementing multi-scale detection
    
    return results

def detect_person_in_frame(keypoints, bbox, frame_height, frame_width):
    """
    Detect ANY person in the frame regardless of position
    """
    if keypoints is None or len(keypoints) == 0:
        return False, "NO_DETECTION"
    
    # Check which keypoints are visible
    visible_keypoints = []
    for kp in keypoints:
        if kp[0] > 0 and kp[1] > 0:  # x,y > 0 means detected
            visible_keypoints.append(kp)
    
    # For aerial views, different visibility patterns:
    # - Full body visible (walking on deck)
    # - Only head/shoulders visible (swimmers)
    # - Small blobs (distant people)
    
    if bbox is not None:
        bbox_area = (bbox[2] - bbox[0]) * (bbox[3] - bbox[1])
        frame_area = frame_height * frame_width
        relative_size = bbox_area / frame_area
        
        # Very small detections might be distant people
        is_distant = relative_size < 0.03
    else:
        is_distant = False
    
    # Determine what body parts are visible
    head_visible = len([kp for kp in keypoints[:5] if kp[0] > 0]) > 0  # First 5 keypoints are head/face
    upper_body_visible = len([kp for kp in keypoints[5:12] if kp[0] > 0]) > 0  # Shoulders, elbows
    lower_body_visible = len([kp for kp in keypoints[12:] if kp[0] > 0]) > 0  # Hips, knees, ankles
    
    # Classify based on visible body parts
    if head_visible and not upper_body_visible and not lower_body_visible:
        status = "PERSON (HEAD ONLY)"
    elif upper_body_visible and not lower_body_visible:
        status = "PERSON (UPPER BODY)"
    elif lower_body_visible:
        status = "PERSON (FULL BODY)"
    elif is_distant:
        status = "PERSON (DISTANT)"
    else:
        status = "PERSON"
    
    return True, status

def calculate_distress_score_aerial(keypoints_history, bbox_history, frame_height, frame_width):
    """
    Aerial-optimized distress detection focusing on movement patterns
    """
    if len(keypoints_history) < 10:
        return 0
    
    # 1. Analyze movement patterns
    if len(keypoints_history) >= 15 and bbox_history and len(bbox_history) >= 15:
        # Track bbox centers over time for movement analysis
        centers = []
        for bbox in bbox_history[-15:]:
            if bbox is not None:
                center_x = (bbox[0] + bbox[2]) / 2
                center_y = (bbox[1] + bbox[3]) / 2
                centers.append([center_x, center_y])
        
        if len(centers) > 5:
            centers = np.array(centers)
            
            # Calculate movement speed and direction changes
            movements = np.diff(centers, axis=0)
            speeds = np.linalg.norm(movements, axis=1)
            
            # Drowning: either very still (unconscious) or very erratic (panicking)
            avg_speed = np.mean(speeds)
            speed_variance = np.var(speeds)
            
            # Direction changes (more changes = more erratic)
            if len(movements) > 1:
                directions = np.arctan2(movements[:, 1], movements[:, 0])
                direction_changes = np.abs(np.diff(directions))
                direction_change_rate = np.mean(direction_changes) if len(direction_changes) > 0 else 0
            else:
                direction_change_rate = 0
            
            # Scoring logic - can be applied to anyone, not just swimmers
            if avg_speed < 2:  # Very still - possible unconscious
                distress_score = 80 + min(speed_variance * 10, 20)
            elif avg_speed > 20 and direction_change_rate > 1.5:  # Erratic panicking
                distress_score = 70 + min(direction_change_rate * 15, 30)
            else:
                distress_score = 20  # Normal movement
        else:
            distress_score = 10
    else:
        distress_score = 10
    
    return min(int(distress_score), 100)

def send_alert(distress_score, person_id):
    payload = {
        "latitude": 1.348,
        "longitude": 103.68, 
        "distress_score": distress_score,
        "status": "CRITICAL" if distress_score > 70 else "MONITORING" if distress_score > 30 else "NORMAL",
        "person_id": int(person_id)
    }
    try:
        requests.post(BACKEND_URL, json=payload, timeout=0.1)
        if distress_score > 70:
            print(f"🚨 POTENTIAL DISTRESS! Person {person_id} | Score: {distress_score}")
        elif distress_score > 30:
            print(f"⚠️ Monitoring Person {person_id} | Score: {distress_score}")
    except:
        pass

def main():
    # Load model
    model = YOLO(MODEL_PATH)
    
    # Open video
    cap = cv2.VideoCapture(VIDEO_SOURCE)
    
    if not cap.isOpened():
        print(f"❌ Could not open video: {VIDEO_SOURCE}")
        return
    
    # Get video properties
    fps = cap.get(cv2.CAP_PROP_FPS)
    frame_width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    frame_height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    
    print("🚀 Aero-ResQ Aerial Person Detection Active")
    print(f"📹 Video: {VIDEO_SOURCE}")
    print(f"📏 Resolution: {frame_width}x{frame_height}")
    print(f"⚙️  Detection threshold: {DETECTION_CONFIDENCE}")
    print("✅ Detecting ALL people in frame - NO water line restriction")
    
    last_send_time = 0
    frame_count = 0
    bbox_history = {}  # Store bbox history for each person
    
    while cap.isOpened():
        success, frame = cap.read()
        if not success:
            print("📹 End of video")
            break
        
        start_time = time.time()
        frame_count += 1
        
        # Run inference with lower confidence threshold for aerial views
        results = model.track(
            frame, 
            imgsz=640,  # Increased from 320 for better small object detection
            persist=True, 
            tracker="bytetrack.yaml", 
            conf=DETECTION_CONFIDENCE,  # Lower threshold
            verbose=False
        )
        
        # Enhance detection for aerial views
        results = enhance_aerial_detection(results, frame)
        
        # Process ALL detections (no water line restriction)
        if (results[0].keypoints is not None and 
            results[0].boxes is not None and 
            results[0].boxes.id is not None):
            
            keypoints_data = results[0].keypoints.xy.cpu().numpy()
            boxes_data = results[0].boxes.xyxy.cpu().numpy()  # Get bounding boxes
            track_ids = results[0].boxes.id.int().cpu().tolist()
            confidences = results[0].boxes.conf.cpu().numpy()
            
            for i, track_id in enumerate(track_ids):
                # Update history
                if track_id not in person_history:
                    person_history[track_id] = deque(maxlen=MAX_HISTORY)
                    bbox_history[track_id] = deque(maxlen=MAX_HISTORY)
                
                person_history[track_id].append(keypoints_data[i])
                bbox_history[track_id].append(boxes_data[i])
                
                # Detect ANY person in the frame
                person_detected, person_status = detect_person_in_frame(
                    keypoints_data[i], 
                    boxes_data[i], 
                    frame_height, 
                    frame_width
                )
                
                # Calculate distress score based on movement patterns
                distress_score = calculate_distress_score_aerial(
                    list(person_history[track_id]),
                    list(bbox_history[track_id]),
                    frame_height,
                    frame_width
                )
                
                if person_detected:
                    # Color coding based on distress level
                    if distress_score > 70:
                        color = (0, 0, 255)  # Red for distress
                    elif distress_score > 30:
                        color = (0, 165, 255)  # Orange for monitoring
                    else:
                        color = (0, 255, 0)  # Green for normal
                    
                    # Draw bounding box
                    x1, y1, x2, y2 = boxes_data[i].astype(int)
                    cv2.rectangle(frame, (x1, y1), (x2, y2), color, 2)
                    
                    # Create label with all information
                    confidence = confidences[i]
                    label = f"ID:{track_id} | {person_status} | Distress:{distress_score}% | {confidence:.2f}"
                    
                    # Draw label background
                    (label_w, label_h), _ = cv2.getTextSize(label, cv2.FONT_HERSHEY_SIMPLEX, 0.4, 1)
                    cv2.rectangle(frame, (x1, y1-20), (x1+label_w, y1), (0,0,0), -1)
                    
                    # Draw label text
                    cv2.putText(frame, label, (x1, y1-5), 
                               cv2.FONT_HERSHEY_SIMPLEX, 0.4, color, 1)
                    
                    # Draw keypoints if available (visualize body parts)
                    if keypoints_data[i] is not None:
                        for kp in keypoints_data[i]:
                            if kp[0] > 0 and kp[1] > 0:
                                cv2.circle(frame, (int(kp[0]), int(kp[1])), 3, (255,255,255), -1)
                    
                    # Alert for high distress
                    if distress_score > 70 and (time.time() - last_send_time > SEND_INTERVAL):
                        send_alert(distress_score, track_id)
                        last_send_time = time.time()
                        
                        # Highlight with thicker red bounding box
                        cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 0, 255), 4)
        
        # Display FPS
        fps_display = int(1/(time.time()-start_time))
        cv2.putText(frame, f"FPS: {fps_display}", (20, 40), cv2.FONT_HERSHEY_SIMPLEX, 1, (255,255,255), 2)
        
        # Show count of detected people
        person_count = len(person_history) if person_history else 0
        cv2.putText(frame, f"People detected: {person_count}", (20, 80), 
                   cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255,255,255), 2)
        
        # Add legend
        legend_y = frame_height - 60
        cv2.putText(frame, "RED: Distress (>70) | ORANGE: Monitor (30-70) | GREEN: Normal (<30)", 
                   (20, legend_y), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255,255,255), 1)
        
        # Display
        cv2.imshow("Aero-ResQ: Aerial Person Detection (Full Frame)", frame)
        
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break
    
    cap.release()
    cv2.destroyAllWindows()

if __name__ == "__main__":
    main()
