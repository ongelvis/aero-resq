import cv2
import requests
import time
import numpy as np
from collections import deque
from ultralytics import YOLO

# --- CONFIGURATION ---
MODEL_PATH = 'yolov8n-pose.pt' 
BACKEND_URL = "http://localhost:8000/telemetry"
VIDEO_SOURCE = 0  # 0 for webcam, or path to video file
SEND_INTERVAL = 2 
MAX_HISTORY = 45  # Increased for better motion pattern analysis
WATER_LINE_RATIO = 0.6  # Assume bottom 60% of frame is water (adjust based on camera angle)

# Dictionary to store keypoint history: { track_id: deque([frame1_kpts, frame2_kpts, ...]) }
person_history = {}

def is_in_water(keypoints, frame_height):
    """
    Determine if person is likely in water based on vertical position
    """
    if len(keypoints) == 0:
        return False
    
    # Use hip/knee positions to determine if person is low in frame
    # Joint indices: 11=left_hip, 12=right_hip, 13=left_knee, 14=right_knee
    hip_knee_y = []
    for idx in [11, 12, 13, 14]:
        if idx < len(keypoints) and keypoints[idx][1] > 0:
            hip_knee_y.append(keypoints[idx][1])
    
    if not hip_knee_y:
        return False
    
    avg_lower_body_y = np.mean(hip_knee_y)
    water_threshold = frame_height * WATER_LINE_RATIO
    
    return avg_lower_body_y > water_threshold

def detect_swimming_pattern(keypoints_history):
    """
    Detect rhythmic swimming patterns vs erratic drowning motions
    """
    if len(keypoints_history) < 20:
        return False
    
    # Extract wrist positions over time
    l_wrists_y = [f[9][1] for f in keypoints_history if f[9][1] > 0]
    r_wrists_y = [f[10][1] for f in keypoints_history if f[10][1] > 0]
    
    if len(l_wrists_y) < 15 or len(r_wrists_y) < 15:
        return False
    
    # Check for rhythmic pattern (swimming)
    # Swimming typically has alternating, smooth, periodic motion
    l_wrist_diff = np.diff(l_wrists_y)
    r_wrist_diff = np.diff(r_wrists_y)
    
    # Calculate rhythm score (lower = more rhythmic)
    l_rhythm = np.std(l_wrist_diff) / (np.mean(np.abs(l_wrist_diff)) + 0.001)
    r_rhythm = np.std(r_wrist_diff) / (np.mean(np.abs(r_wrist_diff)) + 0.001)
    
    # Check for alternation (swimmers alternate arms)
    # Calculate correlation between left and right wrist movements
    min_len = min(len(l_wrist_diff), len(r_wrist_diff))
    if min_len > 5:
        correlation = np.corrcoef(l_wrist_diff[:min_len], r_wrist_diff[:min_len])[0, 1]
        # Negative correlation indicates alternating motion (swimming)
        is_alternating = correlation < -0.3
    else:
        is_alternating = False
    
    # Rhythmic motion has low rhythm score (< 1.5 typically)
    is_rhythmic = (l_rhythm < 1.5 and r_rhythm < 1.5)
    
    return is_rhythmic and is_alternating

def detect_head_position_anomaly(keypoints_history):
    """
    Detect if head is abnormally low or bobbing (drowning sign)
    """
    if len(keypoints_history) < 15:
        return 0
    
    noses_y = [f[0][1] for f in keypoints_history if f[0][1] > 0]
    
    if len(noses_y) < 10:
        return 0
    
    # Calculate head bobbing (drowning victims often bob vertically)
    head_movement = np.std(noses_y)
    
    # Check if head is consistently low (struggling to keep above water)
    avg_head_height = np.mean(noses_y)
    recent_head_height = np.mean(noses_y[-5:])
    
    # If head is getting lower over time (fatigue/trouble)
    head_trend = recent_head_height - avg_head_height
    
    return {
        'bobbing_intensity': min(head_movement * 2, 50),
        'low_head_score': min(max(0, head_trend * 2), 50)
    }

def detect_arm_motion_anomaly(keypoints_history):
    """
    Detect frantic arm movements vs controlled swimming
    """
    if len(keypoints_history) < 15:
        return 0
    
    # Extract wrist positions
    l_wrists = [(f[9][0], f[9][1]) for f in keypoints_history if f[9][0] > 0 and f[9][1] > 0]
    r_wrists = [(f[10][0], f[10][1]) for f in keypoints_history if f[10][0] > 0 and f[10][1] > 0]
    
    if len(l_wrists) < 10 or len(r_wrists) < 10:
        return 0
    
    # Calculate speed of arm movements
    l_speeds = []
    r_speeds = []
    
    for i in range(1, len(l_wrists)):
        dx = l_wrists[i][0] - l_wrists[i-1][0]
        dy = l_wrists[i][1] - l_wrists[i-1][1]
        l_speeds.append(np.sqrt(dx**2 + dy**2))
    
    for i in range(1, len(r_wrists)):
        dx = r_wrists[i][0] - r_wrists[i-1][0]
        dy = r_wrists[i][1] - r_wrists[i-1][1]
        r_speeds.append(np.sqrt(dx**2 + dy**2))
    
    # Drowning involves frantic, fast movements
    avg_speed = (np.mean(l_speeds) + np.mean(r_speeds)) / 2
    
    # Calculate motion irregularity (drowning is erratic)
    l_motion_irregularity = np.std(l_speeds) / (np.mean(l_speeds) + 0.001)
    r_motion_irregularity = np.std(r_speeds) / (np.mean(r_speeds) + 0.001)
    
    avg_irregularity = (l_motion_irregularity + r_motion_irregularity) / 2
    
    # High speed + high irregularity = drowning
    speed_score = min(avg_speed * 2, 50)
    irregularity_score = min(avg_irregularity * 30, 50)
    
    return speed_score + irregularity_score

def calculate_distress_score(keypoints_history, frame_height):
    """
    Enhanced drowning detection for above-water view
    """
    if len(keypoints_history) < 15:
        return 0
    
    # Get the most recent keypoints
    current_kpts = keypoints_history[-1]
    
    # 1. First check: Is the person actually in the water?
    if not is_in_water(current_kpts, frame_height):
        return 0  # Not in water = not drowning
    
    # 2. Check if person is swimming rhythmically (false positive prevention)
    if detect_swimming_pattern(keypoints_history):
        return 20  # Low score for swimmers
    
    # 3. Analyze head position
    head_anomaly = detect_head_position_anomaly(keypoints_history)
    head_score = head_anomaly['bobbing_intensity'] + head_anomaly['low_head_score']
    
    # 4. Analyze arm motion
    arm_score = detect_arm_motion_anomaly(keypoints_history)
    
    # 5. Check for vertical stability (drowning victims often can't stay vertical)
    if len(keypoints_history) >= 10:
        # Use shoulder positions to check body orientation
        shoulders_y = []
        for f in keypoints_history[-10:]:
            if f[5][1] > 0 and f[6][1] > 0:  # Shoulders
                shoulders_y.append((f[5][1] + f[6][1]) / 2)
        
        if shoulders_y:
            shoulder_variance = np.var(shoulders_y)
            vertical_instability = min(shoulder_variance * 2, 30)
        else:
            vertical_instability = 0
    else:
        vertical_instability = 0
    
    # Final weighted score
    # Drowning: Head issues (40%) + Frantic arms (40%) + Instability (20%)
    final_score = (head_score * 0.4) + (arm_score * 0.4) + (vertical_instability * 0.2)
    
    return min(int(final_score), 100)

def send_alert(distress_score, person_id):
    payload = {
        "latitude": 1.348,
        "longitude": 103.68, 
        "distress_score": distress_score,
        "status": "CRITICAL" if distress_score > 80 else "MONITORING" if distress_score > 40 else "NORMAL",
        "person_id": int(person_id)
    }
    try:
        requests.post(BACKEND_URL, json=payload, timeout=0.1)
        if distress_score > 80:
            print(f"🚨 DROWNING DETECTED! Person {person_id} | Score: {distress_score}")
        elif distress_score > 40:
            print(f"⚠️ Monitoring Person {person_id} | Score: {distress_score}")
    except:
        pass

def main():
    model = YOLO(MODEL_PATH)
    cap = cv2.VideoCapture(VIDEO_SOURCE)
    last_send_time = 0
    
    # Get frame height for water line calculation
    frame_height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    if frame_height == 0:  # In case webcam hasn't started
        frame_height = 480  # Default
    
    print("🚀 Aero-ResQ AI Engine is Live. Analyzing Behaviors...")
    print(f"📏 Frame height: {frame_height}, Water line at {int(frame_height * WATER_LINE_RATIO)}px")
    
    while cap.isOpened():
        success, frame = cap.read()
        if not success: break
        
        frame_height = frame.shape[0]  # Update frame height
        start_time = time.time()

        # Run Inference with Tracking enabled
        results = model.track(frame, imgsz=320, persist=True, tracker="bytetrack.yaml", conf=0.4, verbose=False)

        # Draw water line for visualization
        water_line_y = int(frame_height * WATER_LINE_RATIO)
        cv2.line(frame, (0, water_line_y), (frame.shape[1], water_line_y), (255, 255, 0), 2)
        cv2.putText(frame, "Water Line", (10, water_line_y - 10), 
                    cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 0), 1)

        # Check if any people are detected AND have track IDs
        if results[0].keypoints is not None and results[0].boxes.id is not None:
            keypoints_data = results[0].keypoints.xy.cpu().numpy()
            track_ids = results[0].boxes.id.int().cpu().tolist()
            
            for i, track_id in enumerate(track_ids):
                # Update History for this specific person
                if track_id not in person_history:
                    person_history[track_id] = deque(maxlen=MAX_HISTORY)
                
                person_history[track_id].append(keypoints_data[i])

                # Calculate behavioral score with water context
                distress_score = calculate_distress_score(
                    list(person_history[track_id]), 
                    frame_height
                )

                # Determine status and color
                if distress_score > 80:
                    status = "DROWNING"
                    color = (0, 0, 255)  # Red
                elif distress_score > 40:
                    status = "MONITOR"
                    color = (0, 165, 255)  # Orange
                elif distress_score > 0:
                    status = "SWIMMING" if is_in_water(keypoints_data[i], frame_height) else "WALKING"
                    color = (0, 255, 0)  # Green
                else:
                    status = "SAFE"
                    color = (255, 255, 255)  # White
                
                # Draw the score and status above the person's head
                nose_x, nose_y = keypoints_data[i][0]
                if nose_x > 0:
                    # Background for text
                    cv2.rectangle(frame, 
                                (int(nose_x) - 60, int(nose_y) - 45),
                                (int(nose_x) + 150, int(nose_y) - 5),
                                (0, 0, 0), -1)
                    
                    cv2.putText(frame, f"ID:{track_id} | {distress_score}%", 
                                (int(nose_x) - 55, int(nose_y) - 25), 
                                cv2.FONT_HERSHEY_SIMPLEX, 0.5, color, 2)
                    cv2.putText(frame, status, 
                                (int(nose_x) - 55, int(nose_y) - 10), 
                                cv2.FONT_HERSHEY_SIMPLEX, 0.4, color, 1)

                # Telemetry for high distress
                if distress_score > 80 and (time.time() - last_send_time > SEND_INTERVAL):
                    send_alert(distress_score, track_id)
                    last_send_time = time.time()

        # UI & Performance
        fps = 1 / (time.time() - start_time)
        cv2.putText(frame, f"FPS: {int(fps)}", (20, 40), cv2.FONT_HERSHEY_SIMPLEX, 1, (255, 255, 255), 2)
        
        # Add legend
        cv2.putText(frame, "RED: Drowning | ORANGE: Monitor | GREEN: Swimming | WHITE: Safe", 
                   (20, frame_height - 20), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 255), 1)
        
        cv2.imshow("Aero-ResQ: Enhanced Drowning Detection", frame)
        
        if cv2.waitKey(1) & 0xFF == ord('q'): 
            break

    cap.release()
    cv2.destroyAllWindows()

if __name__ == "__main__":
    main()
