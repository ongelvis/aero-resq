def main():
    model = YOLO(MODEL_PATH)
    cap = cv2.VideoCapture(VIDEO_SOURCE)
    last_send_time = 0
    
    print("🚀 Aero-ResQ AI Engine is Live. Analyzing Behaviors...")
    while cap.isOpened():
        success, frame = cap.read()
        if not success: break
        
        start_time = time.time()

        # Run Inference with Tracking enabled
        results = model.track(frame, imgsz=320, persist=True, tracker="bytetrack.yaml", conf=0.4, verbose=False)

        # Check if any people are detected AND have track IDs
        if results[0].keypoints is not None and results[0].boxes.id is not None:
            keypoints_data = results[0].keypoints.xy.cpu().numpy()
            track_ids = results[0].boxes.id.int().cpu().tolist()
            
            for i, track_id in enumerate(track_ids):
                # 1. Update History for this specific person
                if track_id not in person_history:
                    person_history[track_id] = deque(maxlen=MAX_HISTORY)
                
                person_history[track_id].append(keypoints_data[i])

                # 2. Calculate behavioral score using Member 1B's function
                distress_score = calculate_distress_score(list(person_history[track_id]))

                # 3. Visuals
                is_distress = distress_score > 95
                color = (0, 0, 255) if is_distress else (0, 255, 0)
                
                # Draw the score above the person's head (using Nose coords)
                nose_x, nose_y = keypoints_data[i][0]
                if nose_x > 0:
                    cv2.putText(frame, f"ID:{track_id} | RISK: {distress_score}%", 
                                (int(nose_x) - 50, int(nose_y) - 20), 
                                cv2.FONT_HERSHEY_SIMPLEX, 0.6, color, 2)

                # 4. Telemetry
                if is_distress and (time.time() - last_send_time > SEND_INTERVAL):
                    send_alert(distress_score, track_id)
                    last_send_time = time.time()

        # UI & Performance
        fps = 1 / (time.time() - start_time)
        cv2.putText(frame, f"FPS: {int(fps)}", (20, 40), cv2.FONT_HERSHEY_SIMPLEX, 1, (255, 255, 255), 2)
        cv2.imshow("Aero-ResQ: Behavioral Analysis Core", frame)
        
        if cv2.waitKey(1) & 0xFF == ord('q'): break

    cap.release()
    cv2.destroyAllWindows()

if __name__ == "__main__":
    main()


