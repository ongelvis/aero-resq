import cv2
import requests
import time
import numpy as np
from collections import deque
from ultralytics import YOLO

# --- CONFIGURATION ---
MODEL_PATH = 'yolov8n-pose.pt' 
BACKEND_URL = "http://localhost:8000/telemetry"
VIDEO_SOURCE = 0  # 0 for webcam, or path to video file
SEND_INTERVAL = 2 
MAX_HISTORY = 30  # Number of frames to remember for each person

# Dictionary to store keypoint history: { track_id: deque([frame1_kpts, frame2_kpts, ...]) }
person_history = {}

# --- MEMBER 1B LOGIC: BEHAVIORAL ANALYSIS ---
def calculate_distress_score(keypoints_history):
    """
    Analyzes the last 30 frames of motion for a specific person.
    """
    if len(keypoints_history) < 15:
        return 0

    # Extract Wrist Y-coordinates and Nose Y-coordinates
    # Joint 0=Nose, 9=L_Wrist, 10=R_Wrist
    l_wrists_y = [f[9][1] for f in keypoints_history if f[9][1] > 0]
    r_wrists_y = [f[10][1] for f in keypoints_history if f[10][1] > 0]
    noses_y = [f[0][1] for f in keypoints_history if f[0][1] > 0]

    if not l_wrists_y or not r_wrists_y or not noses_y:
        return 0

    # 1. Frequency check: How often are hands above the nose?
    avg_nose = np.mean(noses_y)
    hands_above_head = sum(1 for y in l_wrists_y if y < avg_nose) + \
                       sum(1 for y in r_wrists_y if y < avg_nose)
    
    # 2. Agitation check: How much are the wrists moving vertically?
    # High standard deviation = splashing/flailing
    agitation = np.std(l_wrists_y) + np.std(r_wrists_y)

    # 3. Final Heuristic (Weights: 40% hands, 60% agitation)
    score = (hands_above_head * 0.5) + (agitation * 1.5)
    
    return min(int(score), 100)

# --- MEMBER 1A INFRASTRUCTURE: THE MACHINE ---
def send_alert(distress_score, person_id):
    payload = {
        "latitude": 1.348,
        "longitude": 103.68, 
        "distress_score": distress_score,
        "status": "CRITICAL" if distress_score > 95 else "MONITORING",
        "person_id": int(person_id)
    }
    try:
        requests.post(BACKEND_URL, json=payload, timeout=0.1)
        print(f"📡 Dispatching Drone to Person {person_id} | Score: {distress_score}")
    except:
        pass

